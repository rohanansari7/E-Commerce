{
  "name": "phonepay_backend_only",
  "version": "1.0.0",
  "description": "Phone-Pay frontend and backend side",
  "main": "index.js",
  "scripts": {
    "install": "cd backend && npm install && cd ../client && npm install",
    "dev:server": "cd backend && npm run dev",
    "dev:client": "cd client && npm start",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"" ,
    "build:client": "cd client && npm run build",
    "build:server": "cd backend && npm start",
    "start": "concurrently \"npm run start:server\" \"npm run build:client\""
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
